<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="reporteEstadistico" language="java"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20"
              xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd">

    <field name="categoria" class="java.lang.String"/>
    <field name="valor"     class="java.lang.Double"/>

    <!-- ═══ TÍTULO ═══ -->
    <title>
        <band height="80">
            <staticText>
                <reportElement x="0" y="10" width="555" height="30" style="TituloStyle"/>
                <text><![CDATA[Reporte Estadístico]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="45" width="555" height="20"/>
                <text><![CDATA[Sistema ShenmyKappai]]></text>
            </staticText>
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="430" y="45" width="125" height="20"/>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- ═══ ENCABEZADO DE COLUMNAS ═══ -->
    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0" y="0" width="277" height="25" style="HeaderStyle"/>
                <text><![CDATA[Categoría]]></text>
            </staticText>
            <staticText>
                <reportElement x="278" y="0" width="277" height="25" style="HeaderStyle"/>
                <text><![CDATA[Valor]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ═══ DETALLE ═══ -->
    <detail>
        <band height="25" splitType="Stretch">
            <textField>
                <reportElement x="0" y="0" width="277" height="25" style="DataStyle"/>
                <textFieldExpression><![CDATA[$F{categoria}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="278" y="0" width="277" height="25" style="DataStyle"/>
                <textFieldExpression><![CDATA[$F{valor}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ═══ PIE DE PÁGINA ═══ -->
    <pageFooter>
        <band height="30">
            <staticText>
                <reportElement x="0" y="5" width="300" height="20"/>
                <text><![CDATA[© ShenmyKappai - Reporte generado automáticamente]]></text>
            </staticText>
            <textField>
                <reportElement x="430" y="5" width="125" height="20"/>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- ═══ ESTILOS ═══ -->
    <style name="TituloStyle" fontName="Arial" fontSize="18" isBold="true"
           hTextAlign="Center" forecolor="#1a237e"/>
    <style name="HeaderStyle" fontName="Arial" fontSize="11" isBold="true"
           hTextAlign="Center" forecolor="#FFFFFF"
           backcolor="#1a237e" mode="Opaque"/>
    <style name="DataStyle" fontName="Arial" fontSize="10"
           hTextAlign="Left" mode="Transparent"/>
</jasperReport>
