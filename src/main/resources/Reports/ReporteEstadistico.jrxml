<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="reporteEstadistico" language="java"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20"
              xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd">

    <field name="categoria" class="java.lang.String"/>
    <field name="valor"     class="java.lang.Double"/>

    <!-- ═══ TÍTULO ═══ -->
    <title height="80">
        <!-- Título del reporte -->
        <element kind="staticText" x="0" y="10" width="555" height="30"
                 style="TituloStyle">
            <text><![CDATA[Reporte Estadístico]]></text>
        </element>
        <!-- Subtítulo con parámetro TITULO -->
        <element kind="staticText" x="0" y="45" width="555" height="20">
            <text><![CDATA[Sistema ShenmyKappai]]></text>
        </element>
        <!-- Fecha -->
        <element kind="textField" x="430" y="45" width="125" height="20" pattern="dd/MM/yyyy HH:mm">
            <expression><![CDATA[new java.util.Date()]]></expression>
        </element>
    </title>

    <!-- ═══ ENCABEZADO DE COLUMNAS ═══ -->
    <columnHeader height="25">
        <element kind="staticText" x="0"   y="0" width="277" height="25" style="HeaderStyle">
            <text><![CDATA[Categoría]]></text>
        </element>
        <element kind="staticText" x="278" y="0" width="277" height="25" style="HeaderStyle">
            <text><![CDATA[Valor]]></text>
        </element>
    </columnHeader>

    <!-- ═══ DETALLE (una fila por registro) ═══ -->
    <detail>
        <band height="25" splitType="Stretch">
            <!-- Categoría -->
            <element kind="textField" x="0" y="0" width="277" height="25" style="DataStyle">
                <expression><![CDATA[$F{categoria}]]></expression>
            </element>
            <!-- Valor -->
            <element kind="textField" x="278" y="0" width="277" height="25" style="DataStyle"
                     pattern="#,##0.00">
                <expression><![CDATA[$F{valor}]]></expression>
            </element>
        </band>
    </detail>

    <!-- ═══ PIE DE PÁGINA ═══ -->
    <pageFooter height="30">
        <element kind="staticText" x="0" y="5" width="300" height="20">
            <text><![CDATA[© ShenmyKappai - Reporte generado automáticamente]]></text>
        </element>
        <element kind="textField" x="430" y="5" width="125" height="20">
            <expression><![CDATA["Página " + $V{PAGE_NUMBER}]]></expression>
        </element>
    </pageFooter>

    <!-- ═══ ESTILOS ═══ -->
    <style name="TituloStyle" fontName="Arial" fontSize="18" isBold="true"
           hTextAlign="Center" forecolor="#1a237e"/>
    <style name="HeaderStyle" fontName="Arial" fontSize="11" isBold="true"
           hTextAlign="Center" forecolor="#FFFFFF"
           backcolor="#1a237e" mode="Opaque"/>
    <style name="DataStyle" fontName="Arial" fontSize="10"
           hTextAlign="Left" mode="Transparent"/>

</jasperReport>
